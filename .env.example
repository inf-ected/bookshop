APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
# Docker: use MAIL_HOST=mailpit | Without Docker: use MAIL_HOST=127.0.0.1
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── MinIO / S3 ──────────────────────────────────────────────────────────────
# Shared endpoint for both buckets (MinIO in dev, real S3 endpoint in prod).
S3_ENDPOINT=http://minio:9000
S3_USE_PATH_STYLE_ENDPOINT=true

# Public bucket — book cover images
S3_PUBLIC_ACCESS_KEY_ID=minioadmin
S3_PUBLIC_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_REGION=us-east-1
S3_PUBLIC_BUCKET=bookshop-public
S3_PUBLIC_URL=http://localhost:9000/bookshop-public

# Private bucket — epub files (pre-signed URLs, TTL configured in bookshop config)
S3_PRIVATE_ACCESS_KEY_ID=minioadmin
S3_PRIVATE_SECRET_ACCESS_KEY=minioadmin
S3_PRIVATE_REGION=us-east-1
S3_PRIVATE_BUCKET=bookshop-private
S3_PRIVATE_URL=
# Override internal Docker endpoint for pre-signed URLs (local dev only)
S3_TEMPORARY_URL_BASE=http://localhost:9000

# MinIO admin credentials (used only by the minio-setup container)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Download URL TTL (minutes) ───────────────────────────────────────────────
DOWNLOAD_URL_TTL=5

# ── Sentry ──────────────────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=

VITE_APP_NAME="${APP_NAME}"

# ── OAuth Providers ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=

# ── Stripe ──────────────────────────────────────────────────────────
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_placeholder
